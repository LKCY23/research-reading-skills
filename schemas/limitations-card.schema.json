{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LimitationsCard",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "author_stated_limitations",
    "inferred_limitations",
    "threats_to_validity"
  ],
  "properties": {
    "author_stated_limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "inferred_limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "threats_to_validity": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
